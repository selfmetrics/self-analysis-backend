// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// npx prisma migrate dev --name init
// npx prisma generate   ->   Prisma Client 생성

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          BigInt   @id @default(autoincrement())
  email       String   @unique
  provider    String
  providerId  String
  nickname    String?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  episodes           Episode[]
  interviewAnswers   InterviewAnswer[]         
  questionTemplates  QuestionTemplate[]        
  interviewTemplates InterviewQuestionTemplate[] 
}

model Episode {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt
  title        String
  content      String?
  eventDate    DateTime
  emotion      String
  emotionScore Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User @relation(fields: [userId], references: [id])
  answers  EpisodeAnswer[]
}

model QuestionTemplate {
  id        BigInt   @id @default(autoincrement())
  question  String
  userId    BigInt?   
  createdAt DateTime  @default(now())

  user      User? @relation(fields: [userId], references: [id])
  answers   EpisodeAnswer[]
}

model EpisodeAnswer {
  id           BigInt @id @default(autoincrement())
  episodeId    BigInt
  questionId   BigInt
  answer       String

  episode   Episode @relation(fields: [episodeId], references: [id])
  question  QuestionTemplate @relation(fields: [questionId], references: [id])
}

model InterviewQuestionTemplate {
  id        BigInt   @id @default(autoincrement())
  question  String
  category  String?   
  userId    BigInt?  
  createdAt DateTime  @default(now())

  user    User? @relation(fields: [userId], references: [id])
  answers InterviewAnswer[]
}

model InterviewAnswer {
  id         BigInt @id @default(autoincrement())
  userId     BigInt
  questionId BigInt
  answer     String

  user     User @relation(fields: [userId], references: [id])
  question InterviewQuestionTemplate @relation(fields: [questionId], references: [id])
}